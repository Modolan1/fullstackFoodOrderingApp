# Stripe test secret key (starts with sk_test_)
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe webhook signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Frontend URL used for Stripe success/cancel redirects
FRONTEND_URL=http://localhost:5173

# JWT signing secret for customer auth
JWT_SECRET=replace_me_with_a_long_random_secret

# Admin credentials for admin dashboard login
ADMIN_EMAIL=admin@fooddelivery.com
ADMIN_PASSWORD=replace_admin_password
ADMIN_NAME=Admin
